# MongoDB connection string
MONGODB_URI=mongodb+srv://hosteldb:hosteldb123@cluster0.zsidncr.mongodb.net/?appName=Cluster0
DB_NAME=smart-hostel

# Backend server port
# This must match the base URL used by the frontend proxy (VITE_API_BASE).
PORT=4000

# Frontend origin for CORS in development
CLIENT_ORIGIN=http://localhost:5173

# Optional Vite API base URL for the frontend
VITE_API_BASE=http://localhost:4000

# JWT settings
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRY=7d
